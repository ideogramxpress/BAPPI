rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, displayName, photoURL, role, createdAt, updatedAt
    //
    // Collection: vendors
    // Fields: uid, storeName, status, riskScore, walletBalance, createdAt
    //
    // Collection: products
    // Fields: id, vendorId, name, price, status, stock, images
    //
    // Collection: orders
    // Fields: id, customerId, totalAmount, status, paymentStatus, createdAt
    //
    // Collection: site_settings
    // Fields: maintenanceMode, siteName, commissionRate
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['SuperAdmin', 'Admin'] ||
          (request.auth.token.email == "aanytime.xpress@gmail.com" && request.auth.token.email_verified == true));
    }

    function isVendor() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Vendor';
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'role', 'createdAt', 'updatedAt']) &&
             data.uid is string && data.email is string && data.role is string;
    }

    function isValidProduct(data) {
      return hasOnlyAllowedFields(['id', 'vendorId', 'name', 'description', 'price', 'categoryId', 'status', 'stock', 'images']) &&
             data.vendorId is string && data.name is string && data.price is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
    }

    match /vendors/{vendorId} {
      allow read: if true; // Publicly visible
      allow create: if isAuthenticated() && isOwner(vendorId);
      allow update: if isAdmin() || (isOwner(vendorId) && request.resource.data.status == resource.data.status);
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isVendor() || isAdmin();
      allow update: if isAdmin() || (isVendor() && resource.data.vendorId == request.auth.uid);
      allow delete: if isAdmin() || (isVendor() && resource.data.vendorId == request.auth.uid);
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.customerId == request.auth.uid || isAdmin() || isVendor());
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isVendor();
    }

    match /site_settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}
